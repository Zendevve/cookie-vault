{
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "cookie-vault@zendevve.github.io",
      "strict_min_version": "109.0"
    }
  },
  "name": "Cookie Vault",
  "version": "1.1.0",
  "description": "Secure cookie backup, restore, and export for yt-dlp, wget, curl, and JDownloader.",
  "permissions": ["cookies", "downloads", "activeTab", "clipboardWrite"],
  "host_permissions": [],
  "offline_enabled": true,
  "action": {
    "default_popup": "index.html",
    "default_title": "Cookie Vault"
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  }
}
